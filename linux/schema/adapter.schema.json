{
  "$schema": "https://json-schema.org",
  "type": "object",
  "required": ["command", "params"],
  "properties": {
    "command": {
      "type": "string",
      "enum": ["subscription", "batchCommand", "resendBirthCertificate"]
    },
    "params": { "type": "object" }
  },
  "anyOf": [
     {
      "properties": {
        "description": "Instruct mqtt-adapter to publish birth certificates for gateway and radio nodes",
        "command": { "const": "resendBirthCertificate" },
        "params": {
          "required": ["timestamp"],
          "properties": {
            "timestamp": { "type": "integer" }
          }
        }
      }
    },
    {
      "properties": {
        "description": "set up a subscription on a radio node. Results will be published in advertisement packages",
        "command": { "const": "subscription" },
        "params": {
          "required": ["subscriptionId", "subscriptionInterval", "nodeAddress", "timestamp"],
          "properties": {
            "subscriptionId": { "type": "integer" },
            "subscriptionInterval": { "type": "integer" },
            "nodeAddress": { "type": "integer" },
            "timestamp": { "type": "integer" }
          }
        }
      }
    },
    {
      "properties": {
        "description": "run a sequence of commands to avoid waking up the node more that neccessary",
        "command": { "const": "batchCommand" },
        "params": {
          "required": ["commandList", "nodeAddress", "timestamp"],
          "properties": {
            "commandList": { "type": "array", "items": {"type": "string"} },
            "nodeAddress": { "type": "integer" },
            "timestamp": { "type": "integer" }
          }
        }
      }
    }
  ]
}

